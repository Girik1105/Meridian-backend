# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional — defaults to SQLite for local dev)
# DATABASE_URL=postgres://user:pass@localhost:5432/meridian

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated, defaults to FRONTEND_URL)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com

# Email (optional — uses console backend when DEBUG=True)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Meridian <hello@meridian.dev>
